# Agent runtime: claude (Claude Agent SDK; rides local Claude Code auth — no key
# needed when the CLI is signed in), ollama (fully local), or langgraph.
ATLAS_PROVIDER=claude

# Only needed for API-key auth of the claude provider outside Claude Code:
# ANTHROPIC_API_KEY=sk-ant-...

# Local model settings (provider=ollama)
ATLAS_OLLAMA_MODEL=llama3.2:3b
ATLAS_OLLAMA_BASE_URL=http://localhost:11434

ATLAS_DB_PATH=atlas.db
ATLAS_SKILLS_DIR=../skills
ATLAS_MAX_RETRIES=2
